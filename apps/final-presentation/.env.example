# Copy to `.env.local` for local dev (not committed).
# On Vercel: Project Settings → Environment Variables.

# Required for production builds: access code for the link gate (not a security boundary).
# Local dev: optional — defaults to SAVINGS when unset. Never commit the real value.
VITE_PORTAL_ACCESS_CODE=

# Production site origin (no trailing slash). Used at build time for og:url, og:image, canonical.
# Example: https://your-project.vercel.app
VITE_SITE_URL=

# Optional: Plausible Analytics — your site hostname as configured in Plausible (not the full URL).
VITE_PLAUSIBLE_DOMAIN=

# Debug (optional): set `VITE_DEBUG_CHAT=1` to log `[useChat]` in the browser console even on a production build.
# Server logs `[chat:api]` in development by default, or set `CHAT_DEBUG=1` in Vercel/CI for the chat function.
# VITE_DEBUG_CHAT=
# CHAT_DEBUG=
