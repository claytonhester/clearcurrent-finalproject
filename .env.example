# Copy to `.env` in this folder and paste real values. `.env` is gitignored.
# Claude Code and other Anthropic CLIs read ANTHROPIC_API_KEY from your environment.
# Load before agents: `set -a && source .env && set +a` (from repo root).

# Anthropic API key (starts with sk-ant-api03-...)
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
